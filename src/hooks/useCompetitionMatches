import { useQuery } from '@tanstack/react-query';
import { getCompetitionMatches } from '../api/competitions';

export const useCompetitionMatches = (
  id: number,
  dateFrom?: string,
  dateTo?: string
) => {
  return useQuery({
    queryKey: ['competitionMatches', id, dateFrom, dateTo],
    queryFn: () => getCompetitionMatches(id, dateFrom, dateTo),
    enabled: !!id,
  });
};